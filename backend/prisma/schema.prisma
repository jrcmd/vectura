generator client {
  provider      = "prisma-client-js"
  // Sur l'image Docker backend: node:20-alpine (musl + openssl 3)
  // Prisma doit générer le Query Engine compatible.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // env var required at runtime; local dev should copy root .env -> backend .env
}

enum Role {
  CHAUFFEUR
  ENTREPRISE
  ADMIN
}

enum UserStatus {
  EN_ATTENTE
  VALIDE
  SUSPENDU
  RADIE
}

enum DocType {
  PERMIS_C
  PERMIS_CE
  FIMO
  FCO
  CARTE_CHRONO
  KBIS
  URSSAF
  RC_PRO
  ADR
  FRIGO
}

enum DocStatus {
  EN_ATTENTE
  VALIDE
  REJETE
  EXPIRE
}






enum TruckType {
  PL
  SPL
  ADR
  FRIGO
}

enum MissionStatus {
  OUVERTE
  POURVUE
  ANNULEE
  TERMINEE
}






enum SanctionType {
  SUSPENSION
  RADIATION
}

enum BillingStatus {
  PENDING
  INVOICED
  PAID
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  role          Role
  status        UserStatus @default(EN_ATTENTE)
  firstName     String?
  lastName      String?
  phone         String?
  city          String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  driverProfile  DriverProfile?
  companyProfile CompanyProfile?

  documents     Document[]
  missions      Mission[]
  createdMissions Mission[] @relation("CreatedBy")
  invoicesAsCompany Invoice[] @relation("CompanyInvoices")

  favoritesAsCompany Favorite[] @relation("FavoriteCompany")
  favoritesAsDriver  Favorite[] @relation("FavoriteDriver")

  sanctions     Sanction[]
  cancellations Cancellation[]


  refreshTokens RefreshToken[]
  resetTokens ResetToken[]
}

model DriverProfile {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id])

  hasPermisC              Boolean  @default(false)
  hasPermisCE             Boolean  @default(false)
  hasADR                  Boolean  @default(false)
  hasFrigo                Boolean  @default(false)
  lateCancellationCount  Int      @default(0)
  qualificationsValid    Boolean  @default(false)
}

model CompanyProfile {
  id          String @id @default(uuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id])
  companyName String
  siret       String?
  address     String?
}

model Document {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  type          DocType
  fileUrl       String
  expiryDate    DateTime?
  status        DocStatus @default(EN_ATTENTE)
  uploadedAt    DateTime @default(now())
  validatedAt    DateTime?
  validatedBy   String?
  rejectionReason String?

  @@unique([userId, type])
  @@index([expiryDate]) // Permet de rechercher rapidement les documents expirés
}

model Mission {
  id              String   @id @default(uuid())
  title           String
  description     String?
  location        String
  latitude        Float?
  longitude       Float?
  missionDate     DateTime
  startTime       String
  endTime         String?
  truckType       TruckType
  hourlyRate      Float
  status          MissionStatus @default(OUVERTE)

  creatorId       String
  creator         User     @relation("CreatedBy", fields: [creatorId], references: [id])

  driverId        String?
  driver          User?    @relation(fields: [driverId], references: [id])
  assignedAt      DateTime?
  acceptedAt      DateTime?

  favoritePriorityHours Int @default(0)
  favoritePriorityStart DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  statusHistory   MissionStatusHistory[]

  billing         Billing?

  @@index([status, missionDate]) // Optimise les recherches de missions ouvertes et datées
  @@index([driverId, status])  // Optimise les requêtes par chauffeur et état de mission
}

model MissionStatusHistory {
  id          String   @id @default(uuid())
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id])
  status      MissionStatus
  changedAt   DateTime @default(now())
  changedBy   String?
  reason      String?
}

model Favorite {
  id        String @id @default(uuid())

  companyId String
  company   User   @relation("FavoriteCompany", fields: [companyId], references: [id])

  driverId String
  driver   User   @relation("FavoriteDriver", fields: [driverId], references: [id])

  priorityHours Int @default(0)

  createdAt DateTime @default(now())

  @@unique([companyId, driverId])
  @@index([companyId, driverId]) // Accélère les recherches de favoris pour un couple entreprise/chauffeur
}


model Sanction {
  id          String   @id @default(uuid())
  driverId    String
  driver      User     @relation(fields: [driverId], references: [id])
  type        SanctionType
  startDate   DateTime @default(now())
  endDate     DateTime?
  reason      String
  missionId   String?
  createdAt   DateTime @default(now())
}

model Cancellation {
  id          String   @id @default(uuid())
  missionId   String  @unique
  driverId    String
  driver      User     @relation(fields: [driverId], references: [id])
  cancelledAt DateTime @default(now())
  isLate      Boolean
  reason      String?
}

model Billing {
  id              String   @id @default(uuid())
  missionId       String   @unique
  mission         Mission  @relation(fields: [missionId], references: [id])

  amountBilled    Float
  amountDriver    Float
  margin          Float
  invoiceId       String?
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])

  invoiceNumber   String?  @unique
  invoiceUrl      String?
  generatedAt     DateTime?
  weekStart       DateTime
  weekEnd         DateTime
  status          BillingStatus @default(PENDING)
}

model Invoice {
  id                  String   @id @default(uuid())
  companyId           String
  company             User     @relation("CompanyInvoices", fields: [companyId], references: [id])

  invoiceNumber       String   @unique
  invoiceUrl          String?
  generatedAt         DateTime?
  weekStart           DateTime
  weekEnd             DateTime
  totalAmountBilled   Float
  totalAmountDriver   Float
  totalMargin         Float
  status              BillingStatus @default(PENDING)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  billings            Billing[]

  @@unique([companyId, weekStart])
}

model NotificationLog {
  id          String   @id @default(uuid())
  type        String
  recipientId String
  email       String
  subject     String
  body        String?
  sentAt      DateTime @default(now())
  status      String
  error       String?
  retryCount  Int      @default(0)
  maxRetries  Int      @default(3)

  @@index([status, retryCount, sentAt])
}

model AuditEvent {
  id           String   @id @default(uuid())
  actorId      String?
  actorRole    Role?
  action       String
  resourceType String?
  resourceId   String?
  ip           String?
  userAgent    String?
  status       String   @default("success")
  message      String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([createdAt]) // Permet de parcourir rapidement les événements par ordre chronologique
}

model IncidentTicket {
  id          String   @id @default(uuid())
  title       String
  severity    String
  status      String   @default("OPEN")
  source      String?
  url         String?
  description String?
  ownerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?

  @@index([status, createdAt])
}

model BackupRun {
  id          String   @id @default(uuid())
  environment String   @default("development")
  startedAt   DateTime @default(now())
  completedAt DateTime?
  status      String   @default("RUNNING")
  backupPath  String?
  sizeBytes   Int?
  error       String?

  @@index([environment, createdAt])
  createdAt   DateTime @updatedAt
}

model CronJob {
  id            String   @id @default(uuid())
  name          String   @unique
  enabled       Boolean  @default(true)
  lastRunAt     DateTime?
  lastStatus    String   @default("PENDING")
  lastDurationMs Int?
  lastError     String?
  nextRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model QaCheck {
  id        String   @id @default(uuid())
  suite     String
  name      String
  status    String   @default("TODO")
  notes     String?
  owner     String?
  dueDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([suite, name])
  @@index([suite, status])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model SmsLog {
  id            String    @id @default(uuid())
  recipientPhone String
  recipientId   String?
  invitationId  String?
  message       String
  provider      String    @default("twilio")
  status        String    @default("QUEUED")
  providerRef   String?
  error         String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
}

model EnrollmentInvitation {
  id           String   @id @default(uuid())
  invitationId String   @unique
  phoneNumber  String
  firstName    String?
  lastName     String?
  invitedBy    String
  status       String   @default("PENDING")
  acceptedAt   DateTime?
  expiresAt    DateTime?
  smsLogId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([invitationId])
  @@index([phoneNumber])
}
