generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CHAUFFEUR
  ENTREPRISE
  ADMIN
}

enum UserStatus {
  EN_ATTENTE
  VALIDE
  SUSPENDU
  RADIE
}

enum DocType {
  PERMIS_C
  PERMIS_CE
  FIMO
  FCO
  CARTE_CHRONO
  KBIS
  URSSAF
  RC_PRO
}

enum DocStatus {
  EN_ATTENTE
  VALIDE
  REJETE
  EXPIRE
}

enum TruckType {
  PL
  SPL
  ADR
  FRIGO
}

enum MissionStatus {
  OUVERTE
  POURVUE
  ANNULEE
  TERMINEE
}

enum SanctionType {
  SUSPENSION
  RADIATION
}

enum BillingStatus {
  PENDING
  INVOICED
  PAID
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  role      Role
  status    UserStatus @default(EN_ATTENTE)
  firstName String?
  lastName  String?
  phone     String?
  city      String?
  latitude  Float?
  longitude Float?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  driverProfile  DriverProfile?
  companyProfile CompanyProfile?

  documents       Document[]
  missions        Mission[]
  createdMissions Mission[]  @relation("CreatedBy")

  favoritesAsCompany Favorite[] @relation("FavoriteCompany")
  favoritesAsDriver  Favorite[] @relation("FavoriteDriver")

  sanctions     Sanction[]
  cancellations Cancellation[]

  refreshTokens RefreshToken[]
}

model DriverProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  hasPermisC            Boolean @default(false)
  hasPermisCE           Boolean @default(false)
  hasADR                Boolean @default(false)
  hasFrigo              Boolean @default(false)
  lateCancellationCount Int     @default(0)
  qualificationsValid   Boolean @default(false)
}

model CompanyProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
  companyName String
  siret       String?
  address     String?
}

model Document {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  type            DocType
  fileUrl         String
  expiryDate      DateTime?
  status          DocStatus @default(EN_ATTENTE)
  uploadedAt      DateTime  @default(now())
  validatedAt     DateTime?
  validatedBy     String?
  rejectionReason String?
}

model Mission {
  id          String        @id @default(uuid())
  title       String
  description String?
  location    String
  latitude    Float?
  longitude   Float?
  missionDate DateTime
  startTime   String
  endTime     String?
  truckType   TruckType
  hourlyRate  Float
  status      MissionStatus @default(OUVERTE)

  creatorId String
  creator   User   @relation("CreatedBy", fields: [creatorId], references: [id])

  driverId   String?
  driver     User?     @relation(fields: [driverId], references: [id])
  assignedAt DateTime?

  favoritePriorityHours Int       @default(0)
  favoritePriorityStart DateTime?

  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  statusHistory MissionStatusHistory[]

  billing Billing?
}

model MissionStatusHistory {
  id        String        @id @default(uuid())
  missionId String
  mission   Mission       @relation(fields: [missionId], references: [id])
  status    MissionStatus
  changedAt DateTime      @default(now())
  changedBy String?
  reason    String?
}

model Favorite {
  id String @id @default(uuid())

  companyId String
  company   User   @relation("FavoriteCompany", fields: [companyId], references: [id])

  driverId String
  driver   User   @relation("FavoriteDriver", fields: [driverId], references: [id])

  createdAt DateTime @default(now())

  @@unique([companyId, driverId])
}

model Sanction {
  id        String       @id @default(uuid())
  driverId  String
  driver    User         @relation(fields: [driverId], references: [id])
  type      SanctionType
  startDate DateTime     @default(now())
  endDate   DateTime?
  reason    String
  missionId String?
  createdAt DateTime     @default(now())
}

model Cancellation {
  id          String   @id @default(uuid())
  missionId   String   @unique
  driverId    String
  driver      User     @relation(fields: [driverId], references: [id])
  cancelledAt DateTime @default(now())
  isLate      Boolean
  reason      String?
}

model Billing {
  id        String  @id @default(uuid())
  missionId String  @unique
  mission   Mission @relation(fields: [missionId], references: [id])

  amountBilled Float
  amountDriver Float
  margin       Float

  invoiceNumber String?       @unique
  invoiceUrl    String?
  generatedAt   DateTime?
  weekStart     DateTime
  weekEnd       DateTime
  status        BillingStatus @default(PENDING)
}

model NotificationLog {
  id          String   @id @default(uuid())
  type        String
  recipientId String
  email       String
  subject     String
  sentAt      DateTime @default(now())
  status      String
  error       String?
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}
