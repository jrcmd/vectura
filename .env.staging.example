# ============================================
# VECTURA — CONFIGURATION STAGING
# ============================================

# --- Application ---
NODE_ENV=staging
PORT=3000
APP_URL=https://staging-api.vectura.fr
FRONTEND_URL=https://staging-app.vectura.fr

# --- Base de données ---
DATABASE_URL=postgresql://vectura:${DB_PASSWORD}@postgres:5432/vectura_staging?schema=public&connection_limit=20&pool_timeout=30

# --- Cache & Sessions ---
REDIS_URL=redis://redis:6379

# --- Sécurité JWT ---
JWT_SECRET=staging-secret-key-for-testing-only
REFRESH_TOKEN_SECRET=staging-refresh-secret-key
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=https://staging-app.vectura.fr

# --- SMTP / Notifications ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=noreply@staging.vectura.fr
SMTP_FROM_NAME=Vectura Staging

# --- Tarification ---
MIN_RATE_PL=25.00
MIN_RATE_SPL=30.00

# --- Fichiers ---
MAX_FILE_SIZE=5242880
UPLOAD_DIR=/app/uploads
BACKUP_DIR=/backups

# --- Géocodage ---
GEO_PROVIDER=openstreetmap
GEO_API_KEY=
MAX_DISTANCE_KM=50

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=json