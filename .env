# Matching
MATCHING_MAX_RADIUS_KM=50

# Tarification (€/heure)
MIN_RATE_PL=25
MIN_RATE_SPL=30

# Marge plateforme (%)
PLATFORM_MARGIN_PERCENT=15

# Uploads
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Frontend
VITE_API_URL=http://localhost:3000/api

DB_PASSWORD=T5NvDXcU3X14EiPQF2yC

# Backup (Priorité 5)
BACKUP_ENCRYPTION_ENABLED=true
