# Base de données
DB_PASSWORD=password
DATABASE_URL=postgresql://vectura:password@localhost:5432/vectura

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
REFRESH_TOKEN_SECRET=your-distinct-refresh-secret-min-32-chars
REFRESH_TOKEN_DAYS=7

# SMTP / Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=noreply@vectura.fr

# Matching
MATCHING_MAX_RADIUS_KM=50

# Tarification (€/heure)
MIN_RATE_PL=25
MIN_RATE_SPL=30

# Marge plateforme (%)
PLATFORM_MARGIN_PERCENT=15

# Uploads
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
INVOICE_DIR=./uploads/invoices
BACKUP_DIR=./backups
BACKUP_ENABLED=true
BACKUP_USE_METADATA_ONLY=false

# Déploiement
NODE_ENV=development
DOMAIN=localhost
SSL_MODE=external
API_BASE_URL=http://localhost:3000/api
FRONTEND_BASE_URL=http://localhost:5173

# Rate limiting (auth endpoints)
# Points = max requests per window, Duration = window in seconds
RATE_LIMIT_POINTS=10
RATE_LIMIT_DURATION=60

# Frontend
VITE_API_URL=http://localhost:3000/api

