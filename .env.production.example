# Production Vectura
DATABASE_URL=postgresql://vectura:${DB_PASSWORD}@postgres-prod:5432/vectura
REDIS_URL=redis://redis-prod:6379
JWT_SECRET=change-this-production-secret-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASS=${SMTP_PASS}
FROM_EMAIL=noreply@vectura.fr
DOMAIN=vectura.fr
SSL_MODE=external
API_BASE_URL=https://api.vectura.fr/api
FRONTEND_BASE_URL=https://vectura.fr
VITE_API_URL=https://api.vectura.fr/api
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=/app/uploads
INVOICE_DIR=/app/uploads/invoices
BACKUP_DIR=/app/backups
BACKUP_ENABLED=true
BACKUP_USE_METADATA_ONLY=false
NODE_ENV=production
